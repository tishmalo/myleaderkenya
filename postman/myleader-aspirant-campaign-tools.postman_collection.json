  "item": [
    {
      "name": "Aspirant Registration",
      "item": [
        {
          "name": "Register Aspirant - Returns Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "Jane Aspirant",
                  "type": "text"
                },
                {
                  "key": "nick_name",
                  "value": "Jane",
                  "type": "text"
                },
                {
                  "key": "username",
                  "value": "jane_aspirant_{{$timestamp}}",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "Password@123",
                  "type": "text"
                },
                {
                  "key": "password_confirmation",
                  "value": "Password@123",
                  "type": "text"
                },
                {
                  "key": "phone_1",
                  "value": "+254700000000",
                  "type": "text"
                },
                {
                  "key": "email_1",
                  "value": "jane{{$timestamp}}@example.com",
                  "type": "text"
                },
                {
                  "key": "position_id",
                  "value": "1",
                  "type": "text"
                },
                {
                  "key": "political_party_id",
                  "value": "1",
                  "type": "text"
                },
                {
                  "key": "county",
                  "value": "Nairobi",
                  "type": "text"
                },
                {
                  "key": "constituency",
                  "value": "Westlands",
                  "type": "text"
                },
                {
                  "key": "ward",
                  "value": "Parklands/Highridge",
                  "type": "text"
                },
                {
                  "key": "about",
                  "value": "A sample aspirant registration from Postman.",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/aspirants/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "aspirants",
                "register"
              ]
            }
          },
          "response": [
            {
              "name": "201 Success - Aspirant registered",
              "status": "Created",
              "code": 201,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"message\": \"Aspirant registration submitted successfully. An admin will review it before it appears publicly.\",\n  \"user\": {\n    \"id\": 25,\n    \"username\": \"jane_aspirant\",\n    \"user_type\": \"aspirant\"\n  },\n  \"token\": \"1|sample-sanctum-token\",\n  \"data\": {\n    \"id\": 12,\n    \"name\": \"Jane Aspirant\",\n    \"approval_status\": \"pending\"\n  }\n}"
            },
            {
              "name": "422 Error - Validation failed",
              "status": "Unprocessable Entity",
              "code": 422,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"message\": \"The name field is required.\",\n  \"errors\": {\n    \"name\": [\n      \"The name field is required.\"\n    ],\n    \"position_id\": [\n      \"The selected position id is invalid.\"\n    ]\n  }\n}"
            }
          ]
        }
